# Copy to infra/.env and adjust for your environment.
# Never commit the real .env file (it is gitignored).
#
#   cd infra && cp .env.example .env

# --- Environment ---
ENVIRONMENT=production
LOG_LEVEL=info

# --- Database ---
# Inside Docker Compose the host is the "postgres" service name (the compose
# file sets DATABASE_URL from the POSTGRES_* values below, so you normally only
# need to edit POSTGRES_PASSWORD). For running the API directly on the host
# (uv run ...), point DATABASE_URL at localhost instead.
DATABASE_URL=postgresql+asyncpg://etf:etf_password@postgres:5432/etf_data

# Credentials used by the postgres container to initialise the database.
# USE A STRONG PASSWORD on any real/VPS deployment.
POSTGRES_USER=etf
POSTGRES_PASSWORD=etf_password
POSTGRES_DB=etf_data
# Host port for Postgres (bound to 127.0.0.1 only; dropped entirely in prod).
POSTGRES_PORT=5432

# --- API ---
API_HOST=0.0.0.0
# Host port the API is published on (container always listens on 8080).
API_PORT=8080
# prod override only: host the API binds to on the VPS (default 127.0.0.1 so a
# reverse proxy / tunnel must front it). Set 0.0.0.0 only if you front it yourself.
API_BIND_HOST=127.0.0.1

# Optional shared Bearer token protecting the /api/v1 surface (passed into the API
# container by the compose `api` service).
#   blank/unset => auth DISABLED (every /api/v1 route open — fine for local dev)
#   non-empty   => every /api/v1 request must send  Authorization: Bearer <token>
# The /health and /health/db probes stay unauthenticated either way (the existing
# Caddy proxies to 127.0.0.1:8080 and does NOT need to know this token).
# On the VPS, set a long random value (e.g. `openssl rand -hex 32`). Never commit
# a real token (this is an example; the real value lives in the gitignored .env).
MIMER_API_TOKEN=

# Comma-separated list of allowed CORS origins.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Portfolio reporting base currency.
BASE_CURRENCY=GBP

# --- Instrument resolver ---
# "stub" works offline (no key); set to "openfigi" to use the OpenFIGI API.
RESOLVER_DEFAULT_PROVIDER=stub
# Optional — only for the live OpenFIGI path. Leave blank to stay offline.
OPENFIGI_API_KEY=

# --- Ingestion source adapters ---
# Default provider adapter per ingestion worker. Fixture providers are offline
# (no API key, no network) so the service works out of the box and tests are
# deterministic. Live adapters slot in behind the same registries and are always
# explicit-only (named via --source); never make a live source the default.
PRICE_SOURCE_DEFAULT=stooq
DISTRIBUTION_SOURCE_DEFAULT=distribution_fixture
ISSUER_FACTS_SOURCE_DEFAULT=issuer_fixture
HOLDINGS_SOURCE_DEFAULT=holdings_fixture
FX_SOURCE_DEFAULT=fx_fixture
DOCUMENT_SOURCE_DEFAULT=document_fixture
RATES_SOURCE_DEFAULT=rates_fixture
