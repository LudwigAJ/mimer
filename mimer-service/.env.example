# Copy to .env and adjust. This file documents the variables the API reads when
# run directly on the host (uv run ...). For Docker Compose, use infra/.env
# (see infra/.env.example). NEVER commit the real .env — it is gitignored.

# --- Environment ---
# Free-form label surfaced in diagnostics/logs (e.g. development | production).
ENVIRONMENT=development
LOG_LEVEL=info

# --- Database ---
# Running on the host, Postgres is on localhost. (Inside Compose the host is the
# "postgres" service name — infra/.env / the compose file override this.)
DATABASE_URL=postgresql+asyncpg://etf:etf_password@localhost:5432/etf_data

# --- API ---
API_HOST=0.0.0.0
API_PORT=8080

# Optional shared Bearer token protecting the /api/v1 surface.
#   blank/unset => auth DISABLED (every /api/v1 route open — fine for local dev)
#   non-empty   => every /api/v1 request must send  Authorization: Bearer <token>
# The /health and /health/db probes stay unauthenticated either way.
# On a VPS, set a long random value (e.g. `openssl rand -hex 32`). Never commit a
# real token (this file is an example; real values live in the gitignored .env).
MIMER_API_TOKEN=

# Comma-separated list of allowed CORS origins.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Portfolio reporting base currency (single base currency — personal service).
BASE_CURRENCY=GBP

# --- Instrument resolver ---
# "stub" works offline (no key); set to "openfigi" to use the OpenFIGI API.
RESOLVER_DEFAULT_PROVIDER=stub
# Optional — only needed for the live OpenFIGI resolver path. Leave blank to stay
# fully offline. Never commit a real key.
OPENFIGI_API_KEY=

# --- Ingestion source adapters ---
# Default provider adapter per ingestion worker. Fixture providers are offline
# (no API key, no network) so the service works out of the box and tests are
# deterministic. Live adapters are always explicit-only (named via --source).
PRICE_SOURCE_DEFAULT=stooq
DISTRIBUTION_SOURCE_DEFAULT=distribution_fixture
ISSUER_FACTS_SOURCE_DEFAULT=issuer_fixture
HOLDINGS_SOURCE_DEFAULT=holdings_fixture
FX_SOURCE_DEFAULT=fx_fixture
DOCUMENT_SOURCE_DEFAULT=document_fixture
RATES_SOURCE_DEFAULT=rates_fixture
